---
import MainLayout from '../layouts/MainLayout.astro';
import { EXPERIENCE, EDUCATION, CERTIFICATIONS } from '../constants';
---

<MainLayout currentView="about">
    <div class="layout-content-container flex flex-col max-w-[800px] flex-1 px-6 md:px-0 py-12 mx-auto">
        <section class="mb-12">
            <h1 class="text-primary tracking-tight text-[48px] font-bold leading-tight pb-6 pt-6 font-silkscreen uppercase">About</h1>
            <p class="text-primary/90 text-lg font-normal leading-relaxed pb-3 pt-1 max-w-2xl">
                I am a software architect focused on building functional, aesthetic, and accessible digital systems. 
                With a deep foundation in engineering and a passion for minimalist aesthetics, I specialize in 
                bridging the gap between robust infrastructure and human-centric design.
            </p>
            <p class="text-primary/70 text-base font-normal leading-relaxed pb-3 pt-4 max-w-2xl">
                Based in the intersection of logic and creativity, I spend my time exploring distributed systems, 
                UI architecture, and the future of collaborative tools. I believe code is most powerful when it's 
                unseen, serving the user through seamless performance.
            </p>
        </section>

        <section class="py-16 mb-16 border-y border-accent-line/10 flex justify-center">
            <div class="flex flex-wrap items-center justify-center gap-x-16 gap-y-10">
                {[
                    { name: 'Email', icon: 'M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z' },
                    { name: 'LinkedIn', icon: 'M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z' },
                    { name: 'GitHub', icon: 'M12 .3a12.1 12.1 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.2 1.9 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.3-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12.1 12.1 0 0 0 12 .3z' },
                    { name: 'X', icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' }
                ].map(social => (
                    <a href="#" class="flex items-center gap-6 text-primary transition-all hover:opacity-70 group no-underline">
                        <div class="size-10 flex items-center justify-center">
                            <svg class="w-full h-full fill-[#fffaf4]" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d={social.icon}></path>
                            </svg>
                        </div>
                        <span class="text-3xl font-semibold tracking-tight">{social.name}</span>
                    </a>
                ))}
            </div>
        </section>

        <section class="mb-16">
            <h2 class="text-primary text-[24px] font-bold leading-tight tracking-[-0.015em] pb-6 border-b border-accent-line/20 font-mono">Experience</h2>
            {EXPERIENCE.map(exp => (
                <div class="flex items-center gap-6 px-0 min-h-[80px] py-6">
                    <div class="text-primary flex items-center justify-center rounded-lg bg-primary/10 shrink-0 size-14">
                        <span class="material-symbols-outlined text-2xl">{exp.icon}</span>
                    </div>
                    <div class="flex flex-col justify-center">
                        <p class="text-primary text-lg font-medium leading-normal">{exp.role}</p>
                        <p class="text-primary/60 text-sm font-normal leading-normal">{exp.company} | {exp.period}</p>
                    </div>
                </div>
            ))}
        </section>

        <section class="mb-16">
            <h2 class="text-primary text-[24px] font-bold leading-tight tracking-[-0.015em] pb-6 border-b border-accent-line/20 font-mono">Education</h2>
            {EDUCATION.map(edu => (
                <div class="flex items-center gap-6 px-0 min-h-[80px] py-6">
                    <div class="text-primary flex items-center justify-center rounded-lg bg-primary/10 shrink-0 size-14">
                        <span class="material-symbols-outlined text-2xl">{edu.icon}</span>
                    </div>
                    <div class="flex flex-col justify-center">
                        <p class="text-primary text-lg font-medium leading-normal">{edu.degree}</p>
                        <p class="text-primary/60 text-sm font-normal leading-normal">{edu.school} | {edu.period}</p>
                    </div>
                </div>
            ))}
        </section>

        <section class="mb-24">
            <h2 class="text-primary text-[24px] font-bold leading-tight tracking-[-0.015em] pb-6 border-b border-accent-line/20 font-mono">Certifications</h2>
            <div class="grid grid-cols-1 gap-4 pt-6">
                {CERTIFICATIONS.map(cert => (
                    <div class="flex items-center gap-4 bg-primary/5 hover:bg-primary/10 transition-colors p-4 rounded-xl cursor-pointer">
                        <div class="text-primary flex items-center justify-center rounded-lg bg-primary/10 shrink-0 size-12">
                            <span class="material-symbols-outlined">{cert.icon}</span>
                        </div>
                        <div class="flex flex-col justify-center grow">
                            <p class="text-primary text-base font-medium leading-normal">{cert.name}</p>
                            <p class="text-primary/60 text-xs font-normal leading-normal uppercase tracking-wider">{cert.issuer} • {cert.year}</p>
                        </div>
                        <span class="material-symbols-outlined text-primary/30 text-xl">open_in_new</span>
                    </div>
                ))}
            </div>
        </section>
    </div>
</MainLayout>
