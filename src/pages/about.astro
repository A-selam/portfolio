---
import MainLayout from "../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";
import { EXPERIENCE, EDUCATION, CERTIFICATIONS, CONTACTS } from "../constants";
import AboutSections from "../components/AboutSections.astro";
import ListCertificates from "../components/ListCertificates.astro";
---

<MainLayout currentView="about">
  <div
    class="layout-content-container flex flex-col max-w-[800px] flex-1 px-6 md:px-0 py-12 mx-auto"
  >
    <section class="mb-12">
      <h1
        class="text-primary tracking-tight text-[48px] leading-tight pb-6 pt-6 font-silkscreen uppercase"
      >
        About
      </h1>
      <p
        class="text-primary/90 text-lg font-normal leading-relaxed pb-3 pt-1 max-w-2xl"
      >
        I’m a software engineering student and developer who enjoys building
        clean, content-first web applications. I focus on writing understandable
        code, designing simple systems, and choosing tools that age well rather
        than chase trends.
      </p>

      <p
        class="text-primary/70 text-base font-normal leading-relaxed pb-3 pt-4 max-w-2xl"
      >
        My interests sit between backend architecture and frontend structure —
        APIs, databases, authentication, and UI layouts that stay out of the
        way. I like software that feels calm to use, where most of the work
        happens quietly in the background.
      </p>
    </section>

    <section
      class="py-16 mb-16 border-y border-accent-line/10 flex justify-center"
    >
      <div class="flex flex-wrap items-center justify-center gap-x-16 gap-y-10">
        {
          CONTACTS.map((social) => (
            <a
              href={social.url}
              class="flex items-center gap-3 text-primary transition-all hover:opacity-70 group no-underline"
            >
              <Icon name={social.icon} size={30} />
              <span class="text-3xl font-semibold tracking-tight">
                {social.name}
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <AboutSections sectionHeader="Experience" iterable={EXPERIENCE} />
    <AboutSections sectionHeader="Education" iterable={EDUCATION} />

    {CERTIFICATIONS.length > 0 && <ListCertificates />}
  </div>
</MainLayout>
