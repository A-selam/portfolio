---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const displayProjects = await getCollection('projects');
---

<MainLayout currentView="projects">
    <div class="layout-content-container flex flex-col w-full max-w-[800px] flex-1 px-6 md:px-0 pt-24">
        <h1 class="text-primary font-silkscreen text-[48px] md:text-[56px] leading-tight mb-8 uppercase">PROJECTS</h1>
        <p class="text-primary text-2xl md:text-3xl font-normal leading-relaxed mb-16 max-w-2xl">
            Things I’ve made or learned at the companies I have worked for.
        </p>
        
        <div class="mt-8 mb-4">
            <h2 class="text-primary text-sm font-mono uppercase tracking-widest">Recent Work</h2>
        </div>
        <div class="h-[1px] w-full bg-accent-line opacity-30 mb-16"></div>

        <div class="flex flex-col space-y-24">
            {displayProjects.map((project) => (
                <div class="group border-b border-primary/10 pb-12">
                    <div class="flex gap-8 items-start mb-6">
                        <div class="overflow-hidden rounded-xl bg-[#192b43] shrink-0 size-14 border border-primary/20 flex items-center justify-center">
                            {project.data.image && <img src={project.data.image} alt={project.data.title} class="w-full h-full object-cover" />}
                        </div>
                        <div class="flex flex-col flex-1">
                            <div class="flex flex-col gap-1">
                                <h3 class="text-primary text-3xl font-bold leading-none font-mono mb-2">{project.data.title}</h3>
                                <div class="flex flex-wrap gap-2 mb-4">
                                    {project.data.tags.map(tag => (
                                        <span class="px-2 py-0.5 rounded bg-primary/5 text-primary/70 text-[10px] uppercase font-bold tracking-wider border border-primary/20">
                                            {tag}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        </div>
                    </div>
                    <p class="text-primary/70 text-base font-normal leading-relaxed max-w-2xl mb-8">
                        {project.data.description}
                    </p>
                    <div class="flex items-center justify-between w-full">
                        <div class="flex gap-10">
                            <a href="#" class="flex items-center gap-2 text-primary hover:opacity-70 transition-opacity group/link no-underline">
                                <span class="text-[11px] font-bold uppercase tracking-[0.15em]">Live Demo</span>
                                <span class="material-symbols-outlined !text-sm">open_in_new</span>
                            </a>
                            <a href="#" class="flex items-center gap-2 text-primary hover:opacity-70 transition-opacity group/link no-underline">
                                <span class="text-[11px] font-bold uppercase tracking-[0.15em]">View Code</span>
                                <span class="material-symbols-outlined !text-sm">code</span>
                            </a>
                        </div>
                        <a href="#" class="flex items-center gap-2 text-primary hover:opacity-70 transition-opacity group/link ml-auto no-underline">
                            <span class="text-[11px] font-bold uppercase tracking-[0.15em]">Read More</span>
                            <span class="material-symbols-outlined !text-sm">arrow_right_alt</span>
                        </a>
                    </div>
                </div>
            ))}
        </div>

        <div class="w-full flex justify-center py-20 md:py-24">
            <div class="flex flex-col items-center text-center w-full max-w-[800px]">
                <p class="text-primary/70 text-lg font-normal mb-8 leading-relaxed">
                    Interested in more? Check out my other work on GitHub
                </p>
                <a href="#" class="px-8 py-3 border border-accent-line text-primary text-xs font-bold uppercase tracking-[0.2em] hover:bg-accent-line hover:text-background-dark transition-all duration-300 no-underline">
                    Go to my GitHub profile
                </a>
            </div>
        </div>
    </div>
</MainLayout>
