---
import MainLayout from '@/src/layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import BlogList from '@/src/components/BlogList';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<MainLayout currentView="blog">
    <div class="w-full max-w-[800px] flex flex-col py-24 px-6 md:px-0">
        <section class="mb-16">
            <h1 class="font-silkscreen text-5xl md:text-7xl font-bold tracking-tight uppercase text-primary mb-6">
                Blog
            </h1>
            <p class="text-lg md:text-xl font-normal opacity-70 max-w-xl text-primary">
                Thoughts on software architecture, minimal design, and building for the long-term web.
            </p>
        </section>

        <BlogList client:load allPosts={sortedPosts} posts={sortedPosts} />
    </div>
</MainLayout>
