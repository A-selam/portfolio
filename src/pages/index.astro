---
import MainLayout from "../layouts/MainLayout.astro";
import { SKILLS } from "../constants";

import { Icon } from "astro-icon/components";

import Hero from "../components/Hero.astro";
import FeaturedProjects from "../components/FeaturedProjects.astro";
import LatestWriting from "../components/LatestWriting.astro";
import SectionHeader from "../components/SectionHeader.astro";
---

<MainLayout currentView="home">
  <div class="w-full max-w-[800px] flex flex-col gap-32 py-24 px-6 md:px-0">
    {/* Hero */}
    <Hero
      H1="Hello, My name is Abduselam"
      p="I build simple, well-structured web systems and write about what I learn along the way."
      link={true}
    />

    {/* Featured Projects */}
    <FeaturedProjects />

    {/* Latest Writing */}
    <LatestWriting />

    {/* Technical Skills */}
    <section class="flex flex-col">
      <SectionHeader h2="Technical Skills" a="" />
      <div class="flex flex-wrap gap-3">
        {
          SKILLS.map((skill) => (
            <div class="flex items-center gap-2 px-4 py-2 bg-transparent rounded-full text-primary text-sm border border-skill-border hover:bg-white/5 transition-all cursor-default">
              <span class="material-symbols-outlined text-sm text-[#fffaf4]">
                <Icon name={skill.icon} />
              </span>
              <span>{skill.name}</span>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</MainLayout>
