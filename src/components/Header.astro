---
const {currentView} = Astro.props
---

<div class={`w-full flex justify-center }`}>
          <div class="w-full max-w-[800px] flex flex-col px-6 md:px-0">
            <header class="flex items-center justify-between py-7">
              <a
                href="/"
                class="flex items-center gap-3 text-primary cursor-pointer no-underline"
              >
                <h1 class="text-xl font-bold tracking-tight">@a-selam</h1>
              </a>
              <nav class="hidden md:flex items-center gap-6 md:gap-10">
                <a
                  href="/"
                  class={`text-sm md:text-base font-bold transition-opacity hover:opacity-70 no-underline ${currentView === "home" ? "text-primary" : "text-primary/70"}`}
                >
                  Home
                </a>
                <a
                  href="/projects"
                  class={`text-sm md:text-base font-bold transition-opacity hover:opacity-70 no-underline ${currentView === "projects" ? "text-primary" : "text-primary/70"}`}
                >
                  Projects
                </a>
                <a
                  href="/blog"
                  class={`text-sm md:text-base font-bold transition-opacity hover:opacity-70 no-underline ${currentView === "blog" || currentView === "blog-post" ? "text-primary underline underline-offset-4 decoration-primary" : "text-primary/70"}`}
                >
                  Blog
                </a>
                <a
                  href="/about"
                  class={`text-sm md:text-base font-bold transition-opacity hover:opacity-70 no-underline ${currentView === "about" ? "text-primary" : "text-primary/70"}`}
                >
                  About
                </a>
              </nav>

              <button 
                id="mobile-menu-btn" 
                class="md:hidden flex items-center justify-center p-2 -mr-2 text-primary focus:outline-none z-50 transition-transform active:scale-95"
                aria-label="Toggle menu"
              >
                <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
                <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </header>

            <div id="mobile-menu" class="hidden flex-col items-center gap-2 pb-6 pt-2 mb-4 bg-transparent md:hidden animate-in slide-in-from-top-2 fade-in duration-200">
              <a
                href="/"
                class={`text-lg font-bold transition-opacity hover:opacity-70 no-underline w-full text-center py-3 rounded-xl ${currentView === "home" ? "text-primary bg-primary/5" : "text-primary/70"}`}
              >
                Home
              </a>
              <a
                href="/projects"
                class={`text-lg font-bold transition-opacity hover:opacity-70 no-underline w-full text-center py-3 rounded-xl ${currentView === "projects" ? "text-primary bg-primary/5" : "text-primary/70"}`}
              >
                Projects
              </a>
              <a
                href="/blog"
                class={`text-lg font-bold transition-opacity hover:opacity-70 no-underline w-full text-center py-3 rounded-xl ${currentView === "blog" || currentView === "blog-post" ? "text-primary bg-primary/5 underline underline-offset-4 decoration-primary" : "text-primary/70"}`}
              >
                Blog
              </a>
              <a
                href="/about"
                class={`text-lg font-bold transition-opacity hover:opacity-70 no-underline w-full text-center py-3 rounded-xl ${currentView === "about" ? "text-primary bg-primary/5" : "text-primary/70"}`}
              >
                About
              </a>
            </div>

            <div class="h-[1px] w-full bg-accent-line opacity-30"></div>
          </div>
        </div>

<script>
  const setupMobileMenu = () => {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');

    if (mobileMenuBtn && mobileMenu && hamburgerIcon && closeIcon) {
      // Remove inline onclick if using event listeners to prevent duplicates across view transitions
      const newBtn = mobileMenuBtn.cloneNode(true);
      mobileMenuBtn.parentNode.replaceChild(newBtn, mobileMenuBtn);

      newBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
        mobileMenu.classList.toggle('flex');
        hamburgerIcon.classList.toggle('hidden');
        closeIcon.classList.toggle('hidden');
      });
    }
  };

  setupMobileMenu();
  document.addEventListener('astro:page-load', setupMobileMenu);
</script>