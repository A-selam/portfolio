---
interface Props {
  title?: string;
  description?: string;
  currentView?: string;
}

const {
  title = "DevPortfolio",
  description = "My personal portfolio",
  currentView,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Silkscreen:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      body {
        font-family: "Space Grotesk", sans-serif;
      }
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
        vertical-align: middle;
      }
    </style>
  </head>
  <body class="bg-background-dark text-primary min-h-screen">
    <div
      class="relative flex h-auto min-h-screen w-full flex-col group/design-root overflow-x-hidden"
    >
      <div class="layout-container flex h-full grow flex-col">
        {/* Header */}
        <div class={`w-full flex justify-center }`}>
          <div class="w-full max-w-[800px] flex flex-col px-6 md:px-0">
            <header class="flex items-center justify-between py-7">
              <a
                href="/"
                class="flex items-center gap-3 text-primary cursor-pointer no-underline"
              >
                <h1 class="text-xl font-bold tracking-tight">@a-selam</h1>
              </a>
              <nav class="flex items-center gap-6 md:gap-10">
                <a
                  href="/"
                  class={`text-sm md:text-base font-bold transition-opacity hover:opacity-70 no-underline ${currentView === "home" ? "text-primary" : "text-primary/70"}`}
                >
                  Home
                </a>
                <a
                  href="/projects"
                  class={`text-sm md:text-base font-bold transition-opacity hover:opacity-70 no-underline ${currentView === "projects" ? "text-primary" : "text-primary/70"}`}
                >
                  Projects
                </a>
                <a
                  href="/blog"
                  class={`text-sm md:text-base font-bold transition-opacity hover:opacity-70 no-underline ${currentView === "blog" || currentView === "blog-post" ? "text-primary underline underline-offset-4 decoration-primary" : "text-primary/70"}`}
                >
                  Blog
                </a>
                <a
                  href="/about"
                  class={`text-sm md:text-base font-bold transition-opacity hover:opacity-70 no-underline ${currentView === "about" ? "text-primary" : "text-primary/70"}`}
                >
                  About
                </a>
              </nav>
            </header>
            <div class="h-[1px] w-full bg-accent-line opacity-30"></div>
          </div>
        </div>

        {/* Main Content */}
        <main class="w-full flex justify-center flex-1">
          <slot />
        </main>

        {/* Footer */}
        <footer
          class={`w-full flex justify-center py-10 ${currentView === "blog-post" ? "bg-background-dark" : ""}`}
        >
          <div
            class="layout-content-container flex flex-col w-full max-w-[800px] items-center px-6 md:px-0"
          >
            <div class="w-full h-[1px] bg-accent-line mb-8 opacity-30"></div>
            <div class="flex flex-col items-center">
              <!-- <div class="size-3 rounded-full border border-primary flex items-center justify-center mb-6"></div> -->
              <p
                class="text-primary/50 text-[10px] font-mono tracking-widest uppercase"
              >
                © Abduselam Sultan Zakir — 2026
              </p>
            </div>
          </div>
        </footer>
      </div>
    </div>
  </body>
</html>
